{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "target": "esnext",
    "lib": ["esnext", "dom"],
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    
    "strict": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    
    "jsx": "react-jsx",
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true, 
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "test", "ui"]
}