# Your wallet private key (EOA or Magic export)
WALLET_PRIVATE_KEY=0x
# Alias supported by loader: PRIVATE_KEY
# PRIVATE_KEY=0xYourPrivateKey

# Polymarket profile / proxy address (required for Magic/email; leave empty for EOA)
PROXY_WALLET_ADDRESS=0x
# Alias supported by loader: FUNDER_ADDRESS
# FUNDER_ADDRESS=0xYourPolymarketProfileAddress

# 0 = EOA (MetaMask etc), 1 = Magic/email (proxy), 2 = Gnosis Safe
SIGNATURE_TYPE=0

# Optional API endpoints
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
# Alias supported by loader: CLOB_HOST
# CLOB_HOST=https://clob.polymarket.com

CHAIN_ID=137
# Optional RPC override for USDC balance validation
POLYGON_RPC_URL=https://polygon-rpc.com
# Optional RPC override for Amoy (used if CHAIN_ID is not 137)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Arbitrage strategy markets (symbol:timeframe), comma-separated.
# Requested setup for BTC 5m and 15m:
ARBITRAGE_MARKETS=btc:5m,btc:15m

# true = simulation, false = live orders (or set PRODUCTION=true for live mode)
SIMULATION_MODE=true
# Alias supported by loader: PRODUCTION (inverse semantics)
# PRODUCTION=false

# Strategy tuning
ARBITRAGE_CHECK_INTERVAL_MS=5000
ARBITRAGE_ORDER_USD=20
ARBITRAGE_OBI_DEPTH_LEVELS=5
ARBITRAGE_TREND_THRESHOLD=0.05
